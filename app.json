{
  "expo": {
    "name": "kaizen",
    "slug": "kaizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adhvaithkul.kaizen"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E0E11",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "icon": "./assets/icon.png",
      "config": {
        "description": "Kaizen - Build better habits",
        "themeColor": "#0E0E11"
      }
    },
    "extra": {
      "eas": {
        "projectId": "9ddc35b0-b680-4c20-8ab5-6f95fa39651c"
      }
    },
    "owner": "adhvaithkul",
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Kaizen to use the camera because you need a photo to prove your habit completion."
        }
      ]
    ]
  }
}
